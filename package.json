		"@iconify/svelte": "^5.2.2",
		"@neoconfetti/svelte": "^2.2.2",
		"@rollup/plugin-json": "^6.1.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^24",
		"daisyui": "^5.5.23",
		"eslint": "^10.4.1",
