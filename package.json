		"svelte-check": "^4.6.0",
		"svelte-cookie": "^1.0.1",
		"svelte-persisted-store": "^0.12.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16"
